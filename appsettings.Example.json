{
  "ConnectionStrings": {
    "Postgres": "Host=YOUR_HOST;Port=5432;Database=YOUR_DATABASE;Username=YOUR_USERNAME;Password=YOUR_PASSWORD;Pooling=true;Minimum Pool Size=20;Maximum Pool Size=500;Timeout=15;Command Timeout=30"
  },
  "App": {
    "UploadRoot": "D:\\Data\\SaveraApi\\storage\\app",
    "AdminImageBaseUrl": "https://your-admin-host/image/",
    "TokenLifetimeHours": 168,
    "MaxRequestBodyBytes": 5242880,
