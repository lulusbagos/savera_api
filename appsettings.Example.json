    "FileQueuePollMs": 200,
    "FileQueueMaxAttempts": 5,
    "FileQueueBaseRetrySeconds": 2,
    "FileQueueWorkerConcurrency": 4,
    "MaintenanceCleanupEnabled": true,
    "MaintenanceRetentionDays": 30,
    "MaintenanceIntervalMinutes": 60,
    "PasswordDecryptKey": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
